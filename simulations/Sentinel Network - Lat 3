#
# PURPOSE:
#   Quantify how quickly the Sentinel Network can:
#     • Decide autonomously
#     • Retask sensors
#     • Reprioritize data flows
#
#   This defines Sentinel as a closed-loop planetary system,
#   not a passive sensing constellation.
#
# IMPORTANT:
#   • This is NOT payload-specific slew modeling.
#   • This is a command & control elasticity model.
#
# TRACEABILITY:
#   • AI-3 compute degradation (locked)
#   • LAT-1 detection
#   • LAT-2 awareness pipeline
#   • Sentinel v4.6 constellation topology
# =====================================================================

# ----------------------- Constants ------------------------------------
MINUTES_PER_SECOND = 1.0 / 60.0

# ----------------------- AI Decision Latency --------------------------
# Onboard autonomy classification, confidence gating, and decision issuance

AI_DECISION_BEST_SEC     = 5.0
AI_DECISION_NOMINAL_SEC  = 15.0
AI_DECISION_WORST_SEC    = 60.0

# ----------------------- Command Propagation --------------------------
# Inter-satellite crosslink retasking latency

# Local: same spacecraft
LOCAL_PROP_SEC = 1.0

# Regional: same orbital plane / adjacent planes
REGIONAL_PROP_BEST_SEC    = 10.0
REGIONAL_PROP_NOMINAL_SEC = 30.0
REGIONAL_PROP_WORST_SEC   = 90.0

# Global: constellation-wide behavioral change
GLOBAL_PROP_BEST_SEC    = 60.0
GLOBAL_PROP_NOMINAL_SEC = 180.0
GLOBAL_PROP_WORST_SEC   = 600.0

# ----------------------- Loss / Degradation Factor --------------------
# Propagation penalty under severe constellation loss
DEGRADED_MULTIPLIER = 2.0  # 75% satellite loss case

# ----------------------- Scenarios ------------------------------------
scenarios = {
    "LOCAL RESPONSE": {
        "ai": AI_DECISION_BEST_SEC,
        "prop": LOCAL_PROP_SEC
    },
    "REGIONAL (NOMINAL)": {
        "ai": AI_DECISION_NOMINAL_SEC,
        "prop": REGIONAL_PROP_NOMINAL_SEC
    },
    "GLOBAL (NOMINAL)": {
        "ai": AI_DECISION_NOMINAL_SEC,
        "prop": GLOBAL_PROP_NOMINAL_SEC
    },
    "GLOBAL (WORST CASE)": {
        "ai": AI_DECISION_WORST_SEC,
        "prop": GLOBAL_PROP_WORST_SEC
    },
    "GLOBAL (CATASTROPHIC LOSS)": {
        "ai": AI_DECISION_WORST_SEC,
        "prop": GLOBAL_PROP_WORST_SEC * DEGRADED_MULTIPLIER
    }
}

# ----------------------- Compute Totals -------------------------------
results = {}

for name, s in scenarios.items():
    total_sec = s["ai"] + s["prop"]
    total_min = total_sec * MINUTES_PER_SECOND
    results[name] = total_min

# ----------------------- Report ---------------------------------------
print("=" * 78)
print("SENTINEL NETWORK v4.6 — LAT-3 DECISION ELASTICITY ANALYSIS")
print("=" * 78)

for name, t in results.items():
    print(f"{name:<30}: {t:6.2f} minutes")

